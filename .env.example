# Anthropic director call
ANTHROPIC_API_KEY=sk-ant-...
DIRECTOR_MODEL=claude-opus-4-8
DIRECTOR_MAX_TOKENS=4096

# Brand Gravity client
# BG_MODE=fixture  -> serve slices from data/bg_fixtures (default; RAM buckets not yet connected)
# BG_MODE=http     -> call the live /v1/context endpoint
BG_MODE=fixture
BG_BASE_URL=https://bg-admin.donercolle.dev
BG_API_KEY=

# Local draft store
DRAFT_STORE_PATH=data/draftstore.sqlite

# Where Substance rows are appended (xlsx)
SUBSTANCE_OUT_PATH=out/substance_rows.xlsx
