# Anthropic director call
ANTHROPIC_API_KEY=sk-ant-...
DIRECTOR_MODEL=claude-opus-4-8
DIRECTOR_MAX_TOKENS=4096

# Brand Gravity client
# BG_MODE=fixture  -> serve slices from data/bg_fixtures (default; RAM buckets not yet connected)
# BG_MODE=http     -> call the live /v1/context endpoint
BG_MODE=fixture
BG_BASE_URL=https://bg-admin.donercolle.dev
BG_API_KEY=

# Draft store backend: "local" (SQLite, dev) or "upstash" (Redis, serverless/Vercel)
DRAFT_STORE_BACKEND=local
DRAFT_STORE_PATH=data/draftstore.sqlite
# For DRAFT_STORE_BACKEND=upstash (auto-injected by the Vercel Upstash integration;
# confirm exact names with `vercel env pull` — may be KV_REST_API_URL/TOKEN)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Where Substance rows are appended (xlsx). On Vercel set to /tmp/substance_rows.xlsx
# (read-only FS except /tmp); GET /substance.xlsx rebuilds it from the store anyway.
SUBSTANCE_OUT_PATH=out/substance_rows.xlsx
